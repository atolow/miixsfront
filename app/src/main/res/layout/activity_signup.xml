<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- 타이틀 -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="프로필 만들기"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp" />

            <!-- 이미지 업로드 영역 (3개) -->
            <LinearLayout
                android:id="@+id/llImageUpload"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp">

                <!-- 이미지 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardImage1"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#F5F5F5"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/ivImage1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                </com.google.android.material.card.MaterialCardView>

                <!-- 이미지 2 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardImage2"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#F5F5F5"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/ivImage2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                </com.google.android.material.card.MaterialCardView>

                <!-- 이미지 3 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardImage3"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#F5F5F5"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/ivImage3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- 드래그 안내 텍스트 -->
            <TextView
                android:id="@+id/tvDragHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사진을 드래그해서 순서를 변경할 수 있어요"
                android:textSize="12sp"
                android:textColor="#999999"
                app:layout_constraintTop_toBottomOf="@id/llImageUpload"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp" />

            <!-- 닉네임 -->
            <TextView
                android:id="@+id/tvNicknameLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="닉네임"
                android:textSize="16sp"
                android:textColor="#000000"
                app:layout_constraintTop_toBottomOf="@id/tvDragHint"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <View
                android:id="@+id/viewNicknameDivider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tvNicknameLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNickname"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="닉네임을 입력해주세요"
                android:textColorHint="#FF0000"
                android:textSize="16sp"
                android:textColor="#000000"
                android:background="@android:color/transparent"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:inputType="text"
                app:layout_constraintTop_toBottomOf="@id/viewNicknameDivider"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/etNickname"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 아이디 -->
            <TextView
                android:id="@+id/tvUsernameLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="아이디"
                android:textSize="16sp"
                android:textColor="#000000"
                app:layout_constraintTop_toBottomOf="@id/etNickname"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tvUsernameLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUsername"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="아이디를 입력하세요 (5-15자)"
                android:textSize="16sp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:background="@android:color/transparent"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:inputType="text"
                android:maxLength="15"
                app:layout_constraintTop_toBottomOf="@id/tvUsernameLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/etUsername"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 비밀번호 -->
            <TextView
                android:id="@+id/tvPasswordLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="비밀번호"
                android:textSize="16sp"
                android:textColor="#000000"
                app:layout_constraintTop_toBottomOf="@id/etUsername"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="비밀번호를 입력하세요 (영소문자, 숫자 포함, 8-20자)"
                android:textSize="16sp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:background="@android:color/transparent"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:inputType="textPassword"
                android:maxLength="20"
                app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/etPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 비밀번호 확인 -->
            <TextView
                android:id="@+id/tvPasswordConfirmLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="비밀번호 확인"
                android:textSize="16sp"
                android:textColor="#000000"
                app:layout_constraintTop_toBottomOf="@id/etPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tvPasswordConfirmLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPasswordConfirm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="비밀번호를 다시 입력하세요"
                android:textSize="16sp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:background="@android:color/transparent"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:inputType="textPassword"
                android:maxLength="20"
                app:layout_constraintTop_toBottomOf="@id/tvPasswordConfirmLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 비밀번호 확인 메시지 -->
            <TextView
                android:id="@+id/tvPasswordMatchMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/etPasswordConfirm"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tvPasswordMatchMessage"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 핸드폰 번호 -->
            <TextView
                android:id="@+id/tvPhoneNumberLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="연락처"
                android:textSize="16sp"
                android:textColor="#000000"
                app:layout_constraintTop_toBottomOf="@id/tvPasswordMatchMessage"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tvPhoneNumberLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhoneNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="연락처를 입력하세요"
                android:textSize="16sp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:background="@android:color/transparent"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:inputType="phone"
                app:layout_constraintTop_toBottomOf="@id/tvPhoneNumberLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/etPhoneNumber"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 성별 -->
            <TextView
                android:id="@+id/tvGenderLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="성별을 선택하세요"
                android:textSize="16sp"
                android:textColor="#000000"
                app:layout_constraintTop_toBottomOf="@id/etPhoneNumber"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tvGenderLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <RadioGroup
                android:id="@+id/rgGender"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                app:layout_constraintTop_toBottomOf="@id/tvGenderLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbMale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="남성"
                    android:textColor="#000000"
                    android:buttonTint="#000000" />

                <RadioButton
                    android:id="@+id/rbFemale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="여성"
                    android:layout_marginStart="24dp"
                    android:textColor="#000000"
                    android:buttonTint="#000000" />

            </RadioGroup>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/rgGender"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 나이 -->
            <TextView
                android:id="@+id/tvAgeLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="나이"
                android:textSize="16sp"
                android:textColor="#000000"
                app:layout_constraintTop_toBottomOf="@id/rgGender"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tvAgeLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="나이를 입력하세요"
                android:textSize="16sp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:background="@android:color/transparent"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:inputType="number"
                app:layout_constraintTop_toBottomOf="@id/tvAgeLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/etAge"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 지역 -->
            <TextView
                android:id="@+id/tvLocationLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="지역을 선택하세요"
                android:textSize="16sp"
                android:textColor="#000000"
                app:layout_constraintTop_toBottomOf="@id/etAge"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tvLocationLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:layout_constraintTop_toBottomOf="@id/tvLocationLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvLocationSelected"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="지역을 선택하세요"
                        android:textSize="16sp"
                        android:textColor="#999999" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/arrow_down_float"
                        android:tint="#999999" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/cardLocation"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 자기소개 -->
            <TextView
                android:id="@+id/tvBioLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="회원님을 간단하게 소개해주세요"
                android:textSize="16sp"
                android:textColor="#000000"
                app:layout_constraintTop_toBottomOf="@id/cardLocation"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tvBioLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/etBio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="자기소개를 입력하세요"
                android:textSize="16sp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:background="@android:color/transparent"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:minHeight="80dp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:maxLines="5"
                android:maxLength="20"
                app:layout_constraintTop_toBottomOf="@id/tvBioLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/etBio"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 이메일 -->
            <TextView
                android:id="@+id/tvEmailLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="이메일"
                android:textSize="16sp"
                android:textColor="#000000"
                app:layout_constraintTop_toBottomOf="@id/etBio"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:id="@+id/llEmailContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tvEmailLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="이메일을 입력하세요"
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:textColorHint="#999999"
                    android:background="@android:color/transparent"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:inputType="textEmailAddress"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="인증코드 전송"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4A90E2"
                    app:cornerRadius="8dp"
                    android:minHeight="48dp" />

            </LinearLayout>

            <View
                android:id="@+id/viewEmailDivider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/llEmailContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 인증 코드 -->
            <TextView
                android:id="@+id/tvVerificationCodeLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="인증 코드"
                android:textSize="16sp"
                android:textColor="#000000"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/viewEmailDivider"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvVerificationCodeLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:id="@+id/llVerificationCodeContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvVerificationCodeLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etVerificationCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="인증 코드 6자리"
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:textColorHint="#999999"
                    android:background="@android:color/transparent"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:inputType="text"
                    android:maxLength="6"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerifyCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="인증 확인"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4A90E2"
                    app:cornerRadius="8dp"
                    android:minHeight="48dp" />

            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/llVerificationCodeContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvEmailVerified"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="✓ 이메일 인증 완료"
                android:textColor="#4CAF50"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/llVerificationCodeContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 숨겨진 필드들 (기존 필드 유지) -->
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />


            <AutoCompleteTextView
                android:id="@+id/actvLocation"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />


            <!-- 프로필 이미지 카드 (기존 호환성) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfileImage"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAddImage"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivProfileImage"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvProfileImageHint"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />


            <!-- 비밀번호 찾기 버튼 -->
            <TextView
                android:id="@+id/tvFindPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="비밀번호 찾기"
                android:textSize="14sp"
                android:textColor="#4A90E2"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvEmailVerified"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp" />

            <!-- 가입하기 버튼 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignup"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="가입하기"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#666666"
                app:cornerRadius="0dp"
                android:enabled="true"
                app:layout_constraintTop_toBottomOf="@id/tvFindPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
