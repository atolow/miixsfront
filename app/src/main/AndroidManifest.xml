<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".MiixsApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Miixs"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>
        
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Miixs.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.Miixs"
            android:windowSoftInputMode="adjustResize"
            android:launchMode="singleTop">
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="miixs.com" android:pathPrefix="/oauth" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.FindPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar"
            android:parentActivityName=".ui.main.MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.OAuthAdditionalInfoActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.profile.TermsOfServiceActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.profile.PrivacyPolicyActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.profile.ChildSafetyActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.chat.ChatRoomActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar" />

        <activity
            android:name=".ui.chat.ImageUploadActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar"
            android:parentActivityName=".ui.chat.ChatRoomActivity" />

        <activity
            android:name=".ui.post.PostDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar" />

        <activity
            android:name=".ui.post.CreatePostActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.profile.BlockedUsersActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.profile.ProfileEditActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs"
            android:parentActivityName=".ui.main.MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.profile.UserProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.payment.PaymentActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar"
            android:parentActivityName=".ui.main.MainActivity"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="miixs" android:host="payment" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.payment.PaymentHistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.Miixs.NoActionBar"
            android:parentActivityName=".ui.main.MainActivity" />

        <service
            android:name=".service.ChatNotificationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>

