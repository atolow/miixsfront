<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <!-- 프로필 이미지 -->
    <ImageView
        android:id="@+id/ivProfileImage"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_profile_circle"
        android:background="@drawable/bg_profile_circle"
        android:clipToOutline="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 읽지 않은 메시지 배지 -->
    <TextView
        android:id="@+id/tvUnreadCount"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/bg_unread_count"
        android:gravity="center"
        android:text="0"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/ivProfileImage"
        app:layout_constraintEnd_toEndOf="@id/ivProfileImage" />

    <!-- 사용자 이름 -->
    <TextView
        android:id="@+id/tvOtherUserName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="사용자 이름"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="@id/ivProfileImage"
        app:layout_constraintStart_toEndOf="@id/ivProfileImage"
        app:layout_constraintEnd_toStartOf="@id/tvTimestamp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp" />

    <!-- 타임스탬프 -->
    <TextView
        android:id="@+id/tvTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="어제"
        android:textSize="13sp"
        android:textColor="#666666"
        app:layout_constraintTop_toTopOf="@id/tvOtherUserName"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 마지막 메시지 -->
    <TextView
        android:id="@+id/tvLastMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="메시지가 없습니다"
        android:textSize="14sp"
        android:textColor="#666666"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/tvOtherUserName"
        app:layout_constraintStart_toStartOf="@id/tvOtherUserName"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- 구분선 -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginStart="72dp"
        app:layout_constraintTop_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

