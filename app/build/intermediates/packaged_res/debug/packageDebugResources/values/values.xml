<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#FF000000</color>
    <color name="blue">#FF2196F3</color>
    <color name="gray_600">#FF757575</color>
    <color name="purple_200">#FFB0E0E6</color>
    <color name="purple_500">#FF4A90E2</color>
    <color name="purple_700">#FF2196F3</color>
    <color name="sky_blue">#FF4A90E2</color>
    <color name="sky_blue_light">#FF87CEEB</color>
    <color name="sky_blue_lighter">#FFB0E0E6</color>
    <color name="sky_blue_pale">#FFE3F2FD</color>
    <color name="status_complete">#4A90E2</color>
    <color name="status_failed">#F44336</color>
    <color name="status_pending">#FF9800</color>
    <color name="teal_200">#FF03DAC5</color>
    <color name="teal_700">#FF018786</color>
    <color name="white">#FFFFFFFF</color>
    <string name="app_name">Miixs</string>
    <style name="Theme.Miixs" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/sky_blue</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>
    <style name="Theme.Miixs.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar"/>
    <style name="Theme.Miixs.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sky_blue</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>
    <style name="Theme.Miixs.PopupOverlay" parent="ThemeOverlay.AppCompat.Light"/>
    <style name="Theme.Miixs.Splash" parent="Theme.Miixs">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>